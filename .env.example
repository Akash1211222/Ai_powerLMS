# ==========================================================================
# FutureCorp Academy — Environment Example
# Copy to `.env` and fill real values. NEVER commit a populated .env.
# ==========================================================================

# ---- Core ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
# Comma-separated list of allowed browser origins for CORS
CORS_ORIGINS=http://localhost:3000

# ---- Database (PostgreSQL) ----
# Matches docker-compose.yml defaults for local dev.
DATABASE_URL=postgresql://fca:fca_dev_password@localhost:5432/fca?schema=public

# ---- Redis (cache + BullMQ jobs) ----
REDIS_URL=redis://localhost:6379

# ---- Auth / JWT ----
# Generate strong secrets: `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace-with-strong-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-different-strong-random-secret
JWT_ACCESS_TTL=900          # seconds (15m)
JWT_REFRESH_TTL=1209600     # seconds (14d)
# Argon2 hashing cost (leave defaults unless you know why)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2

# ---- Rate limiting / brute-force ----
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ---- Object storage (S3-compatible; MinIO locally) ----
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=fca_minio
STORAGE_SECRET_KEY=fca_minio_dev_password
STORAGE_BUCKET=fca-local
STORAGE_FORCE_PATH_STYLE=true

# ---- Email (Mailhog locally; SMTP interface) ----
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="FutureCorp Academy <no-reply@futurecorpacademy.in>"

# ---- AI provider (abstraction; default Anthropic Claude) ----
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-opus-4-8
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_RETRIES=2

# ---- Video provider (Phase 1+; interface stub in Phase 0) ----
VIDEO_PROVIDER=stub

# ---- Observability ----
LOG_LEVEL=debug
# Error-tracking DSN (e.g. Sentry). Empty disables it.
ERROR_TRACKING_DSN=

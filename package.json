{
  "name": "futurecorp-academy",
  "version": "0.1.0",
  "private": true,
  "description": "FutureCorp Academy — AI-powered Learning, Intelligence, Career & Community OS",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @fca/database generate",
    "db:migrate": "pnpm --filter @fca/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @fca/database migrate:deploy",
    "db:seed": "pnpm --filter @fca/database seed",
    "db:seed:demo": "pnpm --filter @fca/database exec tsx prisma/demo-seed.ts",
    "db:studio": "pnpm --filter @fca/database studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "3.4.2",
    "turbo": "2.3.3",
    "typescript": "5.6.3"
  }
}

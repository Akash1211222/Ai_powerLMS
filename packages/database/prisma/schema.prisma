// FutureCorp Academy — Prisma schema
// Phase 0 covers three bounded contexts: IDENTITY, ORG (multi-tenant), OPS.
// Later phases add academics/batches/live/... as separate model groups.
// Design rules: FKs + indexes + unique constraints, timestamps everywhere,
// soft delete only where justified (User), enums for status.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// IDENTITY
// ===========================================================================

enum UserStatus {
  PENDING // registered, email not verified
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique // stored lowercased by the app
  passwordHash  String
  status        UserStatus @default(PENDING)
  emailVerifiedAt DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime? // soft delete — users are rarely hard-deleted (audit)

  profile           Profile?
  roles             UserRole[]
  sessions          Session[]
  orgMemberships    OrganizationMember[]
  emailTokens       EmailVerificationToken[]
  passwordResets    PasswordResetToken[]
  auditLogs         AuditLog[]               @relation("AuditActor")

  // Academics / batches (Phase 1)
  coursesCreated     Course[]            @relation("CourseCreator")
  enrollments        Enrollment[]
  lessonProgress     LessonProgress[]
  batchesCreated     Batch[]             @relation("BatchCreator")
  batchStudentships  BatchStudent[]
  batchTrainerships  BatchTrainer[]
  batchAnnouncements BatchAnnouncement[] @relation("AnnouncementAuthor")

  // Attendance (Phase 1)
  attendanceRecords         AttendanceRecord[]            @relation("AttendanceStudent")
  attendanceMarked          AttendanceRecord[]            @relation("AttendanceMarker")
  attendanceSessionsCreated AttendanceSession[]           @relation("AttendanceSessionCreator")
  correctionRequests        AttendanceCorrectionRequest[] @relation("CorrectionRequester")
  correctionReviews         AttendanceCorrectionRequest[] @relation("CorrectionReviewer")

  // Assignments (Phase 1)
  assignmentsCreated  Assignment[]           @relation("AssignmentCreator")
  submissions         AssignmentSubmission[] @relation("SubmissionStudent")
  evaluationReviews   AssignmentEvaluation[] @relation("EvaluationReviewer")

  // Assessments (Phase 1)
  assessmentsCreated Assessment[]        @relation("AssessmentCreator")
  assessmentAttempts AssessmentAttempt[] @relation("AttemptStudent")

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String
  lastName  String
  avatarUrl String?
  headline  String?
  timezone  String   @default("Asia/Kolkata")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// --- RBAC (data-driven; §6) ---------------------------------------------

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // matches @fca/shared ROLES
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // matches @fca/shared PERMISSIONS values
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// A user holds a role, optionally scoped to an organization (null = platform).
model UserRole {
  id             String   @id @default(cuid())
  userId         String
  roleId         String
  organizationId String?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("user_roles")
}

// --- Sessions & auth tokens ---------------------------------------------

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique // hash of the refresh token, never the raw token
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Login attempts back brute-force protection + login audit (§6, §39).
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

// ===========================================================================
// ORG (multi-tenant; §5)
// ===========================================================================

enum OrganizationType {
  COLLEGE
  COMPANY
  INTERNAL
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  type      OrganizationType   @default(COLLEGE)
  status    OrganizationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  members   OrganizationMember[]
  userRoles UserRole[]
  auditLogs AuditLog[]

  // Academics / batches (Phase 1)
  programs Program[]
  courses  Course[]
  batches  Batch[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// ===========================================================================
// OPS (audit, flags, settings; §7 AUDIT AND OPERATIONS)
// ===========================================================================

model AuditLog {
  id             String   @id @default(cuid())
  actorUserId    String?
  organizationId String?
  action         String // e.g. "auth.login", "user.role.grant"
  targetType     String? // e.g. "User", "Organization"
  targetId       String?
  metadata       Json?
  ipAddress      String?
  requestId      String?
  createdAt      DateTime @default(now())

  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ===========================================================================
// ACADEMICS (Phase 1) — programs, courses, modules, lessons, enrollment
// ===========================================================================

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Program {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courses      Course[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("programs")
}

model Course {
  id             String       @id @default(cuid())
  organizationId String
  programId      String?
  title          String
  slug           String
  summary        String?
  description    String?
  thumbnailUrl   String?
  level          CourseLevel  @default(BEGINNER)
  status         CourseStatus @default(DRAFT)
  createdById    String
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("CourseCreator", fields: [createdById], references: [id])
  modules      CourseModule[]
  enrollments  Enrollment[]
  batches      Batch[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([programId])
  @@map("courses")
}

model CourseModule {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("course_modules")
}

enum LessonType {
  VIDEO
  READING
  QUIZ
  ASSIGNMENT
}

model Lesson {
  id           String     @id @default(cuid())
  moduleId     String
  title        String
  order        Int        @default(0)
  type         LessonType @default(VIDEO)
  contentUrl   String?
  body         String?
  durationSec  Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  module    CourseModule       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  resources LearningResource[]
  progress  LessonProgress[]

  @@index([moduleId])
  @@map("lessons")
}

model LearningResource {
  id        String   @id @default(cuid())
  lessonId  String
  title     String
  url       String
  kind      String   @default("file")
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("learning_resources")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

model Enrollment {
  id         String           @id @default(cuid())
  userId     String
  courseId   String
  batchId    String?
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  completedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batch    Batch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)
  progress CourseProgress?

  @@unique([userId, courseId])
  @@index([courseId, status])
  @@index([batchId])
  @@map("enrollments")
}

model CourseProgress {
  id              String   @id @default(cuid())
  enrollmentId    String   @unique
  completedLessons Int     @default(0)
  totalLessons    Int      @default(0)
  percent         Int      @default(0)
  lastActivityAt  DateTime?
  updatedAt       DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("course_progress")
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model LessonProgress {
  id            String               @id @default(cuid())
  enrollmentId  String
  lessonId      String
  userId        String
  status        LessonProgressStatus @default(NOT_STARTED)
  lastPositionSec Int                @default(0)
  watchedSec    Int                  @default(0)
  completedAt   DateTime?
  updatedAt     DateTime             @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

// ===========================================================================
// BATCHES (Phase 1) — cohorts, membership, schedule, announcements
// ===========================================================================

enum BatchStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

model Batch {
  id             String      @id @default(cuid())
  organizationId String
  courseId       String
  name           String
  code           String
  status         BatchStatus @default(PLANNED)
  capacity       Int?
  startDate      DateTime?
  endDate        DateTime?
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course        Course              @relation(fields: [courseId], references: [id], onDelete: Restrict)
  createdBy     User                @relation("BatchCreator", fields: [createdById], references: [id])
  students      BatchStudent[]
  trainers      BatchTrainer[]
  schedules     BatchSchedule[]
  announcements BatchAnnouncement[]
  enrollments   Enrollment[]
  attendanceSessions AttendanceSession[]
  assignments        Assignment[]
  assessments        Assessment[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([courseId])
  @@map("batches")
}

enum BatchStudentStatus {
  ACTIVE
  REMOVED
  COMPLETED
}

model BatchStudent {
  id        String             @id @default(cuid())
  batchId   String
  userId    String
  status    BatchStudentStatus @default(ACTIVE)
  joinedAt  DateTime           @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId])
  @@index([userId])
  @@map("batch_students")
}

enum BatchTrainerRole {
  LEAD
  ASSISTANT
}

model BatchTrainer {
  id        String           @id @default(cuid())
  batchId   String
  userId    String
  role      BatchTrainerRole @default(LEAD)
  createdAt DateTime         @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId])
  @@index([userId])
  @@map("batch_trainers")
}

model BatchSchedule {
  id        String   @id @default(cuid())
  batchId   String
  title     String
  startsAt  DateTime
  endsAt    DateTime
  location  String?
  createdAt DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, startsAt])
  @@map("batch_schedules")
}

model BatchAnnouncement {
  id        String   @id @default(cuid())
  batchId   String
  authorId  String
  title     String
  body      String
  createdAt DateTime @default(now())

  batch  Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  author User  @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([batchId, createdAt])
  @@map("batch_announcements")
}

// ===========================================================================
// ATTENDANCE (Phase 1) — sessions, records, correction requests (§14)
// ===========================================================================

enum AttendanceSessionStatus {
  OPEN
  CLOSED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// Where a record came from — evidence for auditability (§14).
enum AttendanceSource {
  MANUAL
  LIVE
  CORRECTION
  IMPORT
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceSession {
  id          String                  @id @default(cuid())
  batchId     String
  scheduleId  String?
  title       String
  sessionDate DateTime
  status      AttendanceSessionStatus @default(OPEN)
  createdById String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  batch     Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy User               @relation("AttendanceSessionCreator", fields: [createdById], references: [id])
  records   AttendanceRecord[]

  @@index([batchId, sessionDate])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  sessionId  String
  studentId  String
  status     AttendanceStatus
  source     AttendanceSource @default(MANUAL)
  note       String?
  markedById String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  session     AttendanceSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     User                          @relation("AttendanceStudent", fields: [studentId], references: [id], onDelete: Cascade)
  markedBy    User?                         @relation("AttendanceMarker", fields: [markedById], references: [id], onDelete: SetNull)
  corrections AttendanceCorrectionRequest[]

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendance_records")
}

model AttendanceCorrectionRequest {
  id              String           @id @default(cuid())
  recordId        String
  requestedById   String
  requestedStatus AttendanceStatus
  reason          String
  status          CorrectionStatus @default(PENDING)
  reviewedById    String?
  reviewNote      String?
  reviewedAt      DateTime?
  createdAt       DateTime         @default(now())

  record      AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  requestedBy User             @relation("CorrectionRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User?            @relation("CorrectionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([recordId])
  @@index([status])
  @@map("attendance_correction_requests")
}

// ===========================================================================
// ASSIGNMENTS (Phase 1) — authoring, submission, AI-assisted evaluation (§15)
// ===========================================================================

enum AssignmentDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  EVALUATING
  EVALUATED
  RETURNED
}

// Lifecycle of an evaluation. AI never overwrites a trainer decision (§15):
// once RELEASED with a trainer score, re-evaluation is skipped.
enum EvaluationStatus {
  PENDING
  AI_COMPLETED
  NEEDS_REVIEW
  RELEASED
}

model Assignment {
  id                  String               @id @default(cuid())
  batchId             String
  courseId            String?
  moduleId            String?
  title               String
  description         String?
  instructions        String?
  difficulty          AssignmentDifficulty @default(MEDIUM)
  maxScore            Int                  @default(100)
  dueAt               DateTime?
  allowLate           Boolean              @default(false)
  maxAttempts         Int                  @default(1)
  aiEvaluationEnabled Boolean              @default(true)
  status              AssignmentStatus     @default(DRAFT)
  createdById         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  batch       Batch                  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation("AssignmentCreator", fields: [createdById], references: [id])
  criteria    RubricCriterion[]
  submissions AssignmentSubmission[]

  @@index([batchId, status])
  @@map("assignments")
}

model RubricCriterion {
  id           String  @id @default(cuid())
  assignmentId String
  title        String
  description  String?
  weight       Int     @default(10)
  order        Int     @default(0)

  assignment Assignment                @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  scores     EvaluationCriterionScore[]

  @@index([assignmentId])
  @@map("rubric_criteria")
}

model AssignmentSubmission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  attemptNumber Int              @default(1)
  contentText   String?
  repoUrl       String?
  status        SubmissionStatus @default(DRAFT)
  submittedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  assignment  Assignment            @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student     User                  @relation("SubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  evaluation  AssignmentEvaluation?
  attachments SubmissionAttachment[]

  @@unique([assignmentId, studentId, attemptNumber])
  @@index([studentId])
  @@map("assignment_submissions")
}

model SubmissionAttachment {
  id           String   @id @default(cuid())
  submissionId String
  fileName     String
  url          String
  contentType  String?
  size         Int?
  createdAt    DateTime @default(now())

  submission AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_attachments")
}

model AssignmentEvaluation {
  id           String           @id @default(cuid())
  submissionId String           @unique
  aiScore      Int?
  trainerScore Int?
  finalScore   Int?
  confidence   Float?
  reason       String?
  version      Int              @default(1)
  evaluatedByAi Boolean         @default(false)
  status       EvaluationStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  submission     AssignmentSubmission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewedBy     User?                      @relation("EvaluationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  criterionScores EvaluationCriterionScore[]

  @@map("assignment_evaluations")
}

model EvaluationCriterionScore {
  id           String  @id @default(cuid())
  evaluationId String
  criterionId  String
  score        Int
  comment      String?

  evaluation AssignmentEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterion  RubricCriterion      @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, criterionId])
  @@map("evaluation_criterion_scores")
}

// ===========================================================================
// AI OPERATIONS (§36) — observability for every AI/heuristic job
// ===========================================================================

enum AIJobType {
  ASSIGNMENT_EVALUATION
  QUESTION_GENERATION
  PROGRESS_REPORT
  RECOVERY_PLAN
}

enum AIJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model AIJob {
  id            String      @id @default(cuid())
  type          AIJobType
  status        AIJobStatus @default(QUEUED)
  provider      String?
  model         String?
  promptVersion String?
  inputRef      String? // e.g. submissionId
  output        Json?
  error         String?
  tokensInput   Int?
  tokensOutput  Int?
  latencyMs     Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([type, status])
  @@index([inputRef])
  @@map("ai_jobs")
}

// ===========================================================================
// ASSESSMENTS (Phase 1) — tests/quizzes, auto-grading, topic performance (§16)
// ===========================================================================

enum QuestionType {
  MCQ
  MULTI_SELECT
  TRUE_FALSE
  SHORT_ANSWER
  CODING
  SQL
  CASE_STUDY
  FILE_TASK
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

model Assessment {
  id               String               @id @default(cuid())
  batchId          String
  courseId         String?
  title            String
  description      String?
  timeLimitMin     Int?
  maxAttempts      Int                  @default(1)
  shuffleQuestions Boolean              @default(false)
  passingScore     Int?
  dueAt            DateTime?
  status           AssessmentStatus     @default(DRAFT)
  createdById      String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  batch     Batch               @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy User                @relation("AssessmentCreator", fields: [createdById], references: [id])
  questions Question[]
  attempts  AssessmentAttempt[]

  @@index([batchId, status])
  @@map("assessments")
}

model Question {
  id           String               @id @default(cuid())
  assessmentId String
  type         QuestionType
  prompt       String
  topic        String? // topic tag -> topic-level performance (§16)
  skillTag     String? // links to the skill matrix (Phase 2)
  difficulty   AssignmentDifficulty @default(MEDIUM)
  points       Int                  @default(1)
  order        Int                  @default(0)
  correctText  String? // for auto-graded SHORT_ANSWER (exact/normalized match)
  explanation  String?

  assessment Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  options    QuestionOption[]
  answers    AttemptAnswer[]

  @@index([assessmentId])
  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

model AssessmentAttempt {
  id            String        @id @default(cuid())
  assessmentId  String
  studentId     String
  attemptNumber Int           @default(1)
  status        AttemptStatus @default(IN_PROGRESS)
  score         Int?
  maxScore      Int?
  percent       Int?
  startedAt     DateTime      @default(now())
  submittedAt   DateTime?
  gradedAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assessment      Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student         User              @relation("AttemptStudent", fields: [studentId], references: [id], onDelete: Cascade)
  answers         AttemptAnswer[]
  topicPerformance TopicPerformance[]

  @@unique([assessmentId, studentId, attemptNumber])
  @@index([studentId])
  @@map("assessment_attempts")
}

model AttemptAnswer {
  id                String   @id @default(cuid())
  attemptId         String
  questionId        String
  selectedOptionIds String[] // for MCQ / MULTI_SELECT / TRUE_FALSE
  textAnswer        String?
  isCorrect         Boolean?
  pointsAwarded     Int?
  needsReview       Boolean  @default(false)

  attempt  AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("attempt_answers")
}

// Per-attempt breakdown by topic — the topic-level evidence that drives the
// skill matrix and intervention engine in Phase 2 (§16, §17, §20).
model TopicPerformance {
  id        String @id @default(cuid())
  attemptId String
  topic     String
  correct   Int
  total     Int
  percent   Int

  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, topic])
  @@map("topic_performance")
}

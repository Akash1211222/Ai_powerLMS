// FutureCorp Academy — Prisma schema
// Phase 0 covers three bounded contexts: IDENTITY, ORG (multi-tenant), OPS.
// Later phases add academics/batches/live/... as separate model groups.
// Design rules: FKs + indexes + unique constraints, timestamps everywhere,
// soft delete only where justified (User), enums for status.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// IDENTITY
// ===========================================================================

enum UserStatus {
  PENDING // registered, email not verified
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique // stored lowercased by the app
  passwordHash    String
  status          UserStatus @default(PENDING)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime? // soft delete — users are rarely hard-deleted (audit)

  profile        Profile?
  roles          UserRole[]
  sessions       Session[]
  orgMemberships OrganizationMember[]
  emailTokens    EmailVerificationToken[]
  passwordResets PasswordResetToken[]
  auditLogs      AuditLog[]               @relation("AuditActor")

  // Academics / batches (Phase 1)
  coursesCreated     Course[]            @relation("CourseCreator")
  enrollments        Enrollment[]
  lessonProgress     LessonProgress[]
  batchesCreated     Batch[]             @relation("BatchCreator")
  batchStudentships  BatchStudent[]
  batchTrainerships  BatchTrainer[]
  batchAnnouncements BatchAnnouncement[] @relation("AnnouncementAuthor")

  // Attendance (Phase 1)
  attendanceRecords         AttendanceRecord[]            @relation("AttendanceStudent")
  attendanceMarked          AttendanceRecord[]            @relation("AttendanceMarker")
  attendanceSessionsCreated AttendanceSession[]           @relation("AttendanceSessionCreator")
  correctionRequests        AttendanceCorrectionRequest[] @relation("CorrectionRequester")
  correctionReviews         AttendanceCorrectionRequest[] @relation("CorrectionReviewer")

  // Assignments (Phase 1)
  assignmentsCreated Assignment[]           @relation("AssignmentCreator")
  submissions        AssignmentSubmission[] @relation("SubmissionStudent")
  evaluationReviews  AssignmentEvaluation[] @relation("EvaluationReviewer")

  // Assessments (Phase 1)
  assessmentsCreated Assessment[]        @relation("AssessmentCreator")
  assessmentAttempts AssessmentAttempt[] @relation("AttemptStudent")

  // Notifications & calendar (Phase 1)
  notifications          Notification[]
  notificationPreference NotificationPreference?
  calendarEvents         CalendarEvent[]         @relation("CalendarOwner")

  // Intelligence (Phase 2)
  studentSkills StudentSkill[]
  score         StudentScore?
  riskSnapshots StudentRiskSnapshot[]
  interventions StudentIntervention[]
  weeklyReports WeeklyProgressReport[]

  // Career ecosystem (Phase 3)
  careerProfile        CareerProfile?
  opportunitiesPosted  Opportunity[]         @relation("OpportunityPoster")
  applications         Application[]         @relation("Applicant")
  applicationsReviewed Application[]         @relation("ApplicationReviewer")
  mentorProfile        MentorProfile?
  mentorSlots          MentorSlot[]          @relation("SlotMentor")
  bookingsAsMentor     MentorBooking[]       @relation("BookingMentor")
  bookingsAsStudent    MentorBooking[]       @relation("BookingStudent")
  alumniProfile        AlumniProfile?
  referralsMade        Referral[]            @relation("ReferralReferrer")
  referralsReceived    Referral[]            @relation("ReferralStudent")
  referralsReviewed    Referral[]            @relation("ReferralReviewer")
  communityQuestions   CommunityQuestion[]   @relation("QuestionAuthor")
  communityAnswers     CommunityAnswer[]     @relation("AnswerAuthor")
  communityAnswerVotes CommunityAnswerVote[]
  achievements         Achievement[]

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String
  lastName  String
  avatarUrl String?
  headline  String?
  timezone  String   @default("Asia/Kolkata")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// --- RBAC (data-driven; §6) ---------------------------------------------

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // matches @fca/shared ROLES
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // matches @fca/shared PERMISSIONS values
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// A user holds a role, optionally scoped to an organization (null = platform).
model UserRole {
  id             String   @id @default(cuid())
  userId         String
  roleId         String
  organizationId String?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("user_roles")
}

// --- Sessions & auth tokens ---------------------------------------------

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique // hash of the refresh token, never the raw token
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Login attempts back brute-force protection + login audit (§6, §39).
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

// ===========================================================================
// ORG (multi-tenant; §5)
// ===========================================================================

enum OrganizationType {
  COLLEGE
  COMPANY
  INTERNAL
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  type      OrganizationType   @default(COLLEGE)
  status    OrganizationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  members   OrganizationMember[]
  userRoles UserRole[]
  auditLogs AuditLog[]

  // Academics / batches (Phase 1)
  programs Program[]
  courses  Course[]
  batches  Batch[]

  // Career ecosystem (Phase 3)
  opportunities Opportunity[]

  // Network effects (Phase 4)
  communityQuestions CommunityQuestion[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// ===========================================================================
// OPS (audit, flags, settings; §7 AUDIT AND OPERATIONS)
// ===========================================================================

model AuditLog {
  id             String   @id @default(cuid())
  actorUserId    String?
  organizationId String?
  action         String // e.g. "auth.login", "user.role.grant"
  targetType     String? // e.g. "User", "Organization"
  targetId       String?
  metadata       Json?
  ipAddress      String?
  requestId      String?
  createdAt      DateTime @default(now())

  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ===========================================================================
// ACADEMICS (Phase 1) — programs, courses, modules, lessons, enrollment
// ===========================================================================

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Program {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courses      Course[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("programs")
}

model Course {
  id             String       @id @default(cuid())
  organizationId String
  programId      String?
  title          String
  slug           String
  summary        String?
  description    String?
  thumbnailUrl   String?
  level          CourseLevel  @default(BEGINNER)
  status         CourseStatus @default(DRAFT)
  createdById    String
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?       @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdBy    User           @relation("CourseCreator", fields: [createdById], references: [id])
  modules      CourseModule[]
  enrollments  Enrollment[]
  batches      Batch[]
  courseSkills CourseSkill[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([programId])
  @@map("courses")
}

model CourseModule {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("course_modules")
}

enum LessonType {
  VIDEO
  READING
  QUIZ
  ASSIGNMENT
}

model Lesson {
  id          String     @id @default(cuid())
  moduleId    String
  title       String
  order       Int        @default(0)
  type        LessonType @default(VIDEO)
  contentUrl  String?
  body        String?
  durationSec Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  module    CourseModule       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  resources LearningResource[]
  progress  LessonProgress[]

  @@index([moduleId])
  @@map("lessons")
}

model LearningResource {
  id        String   @id @default(cuid())
  lessonId  String
  title     String
  url       String
  kind      String   @default("file")
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("learning_resources")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  batchId     String?
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batch    Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  progress CourseProgress?

  @@unique([userId, courseId])
  @@index([courseId, status])
  @@index([batchId])
  @@map("enrollments")
}

model CourseProgress {
  id               String    @id @default(cuid())
  enrollmentId     String    @unique
  completedLessons Int       @default(0)
  totalLessons     Int       @default(0)
  percent          Int       @default(0)
  lastActivityAt   DateTime?
  updatedAt        DateTime  @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("course_progress")
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model LessonProgress {
  id              String               @id @default(cuid())
  enrollmentId    String
  lessonId        String
  userId          String
  status          LessonProgressStatus @default(NOT_STARTED)
  lastPositionSec Int                  @default(0)
  watchedSec      Int                  @default(0)
  completedAt     DateTime?
  updatedAt       DateTime             @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

// ===========================================================================
// BATCHES (Phase 1) — cohorts, membership, schedule, announcements
// ===========================================================================

enum BatchStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

model Batch {
  id             String      @id @default(cuid())
  organizationId String
  courseId       String
  name           String
  code           String
  status         BatchStatus @default(PLANNED)
  capacity       Int?
  startDate      DateTime?
  endDate        DateTime?
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course             Course                @relation(fields: [courseId], references: [id], onDelete: Restrict)
  createdBy          User                  @relation("BatchCreator", fields: [createdById], references: [id])
  students           BatchStudent[]
  trainers           BatchTrainer[]
  schedules          BatchSchedule[]
  announcements      BatchAnnouncement[]
  enrollments        Enrollment[]
  attendanceSessions AttendanceSession[]
  assignments        Assignment[]
  assessments        Assessment[]
  calendarEvents     CalendarEvent[]
  riskSnapshots      StudentRiskSnapshot[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([courseId])
  @@map("batches")
}

enum BatchStudentStatus {
  ACTIVE
  REMOVED
  COMPLETED
}

model BatchStudent {
  id       String             @id @default(cuid())
  batchId  String
  userId   String
  status   BatchStudentStatus @default(ACTIVE)
  joinedAt DateTime           @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId])
  @@index([userId])
  @@map("batch_students")
}

enum BatchTrainerRole {
  LEAD
  ASSISTANT
}

model BatchTrainer {
  id        String           @id @default(cuid())
  batchId   String
  userId    String
  role      BatchTrainerRole @default(LEAD)
  createdAt DateTime         @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId])
  @@index([userId])
  @@map("batch_trainers")
}

model BatchSchedule {
  id        String   @id @default(cuid())
  batchId   String
  title     String
  startsAt  DateTime
  endsAt    DateTime
  location  String?
  createdAt DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, startsAt])
  @@map("batch_schedules")
}

model BatchAnnouncement {
  id        String   @id @default(cuid())
  batchId   String
  authorId  String
  title     String
  body      String
  createdAt DateTime @default(now())

  batch  Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  author User  @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([batchId, createdAt])
  @@map("batch_announcements")
}

// ===========================================================================
// ATTENDANCE (Phase 1) — sessions, records, correction requests (§14)
// ===========================================================================

enum AttendanceSessionStatus {
  OPEN
  CLOSED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// Where a record came from — evidence for auditability (§14).
enum AttendanceSource {
  MANUAL
  LIVE
  CORRECTION
  IMPORT
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceSession {
  id          String                  @id @default(cuid())
  batchId     String
  scheduleId  String?
  title       String
  sessionDate DateTime
  status      AttendanceSessionStatus @default(OPEN)
  createdById String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  batch     Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy User               @relation("AttendanceSessionCreator", fields: [createdById], references: [id])
  records   AttendanceRecord[]

  @@index([batchId, sessionDate])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  sessionId  String
  studentId  String
  status     AttendanceStatus
  source     AttendanceSource @default(MANUAL)
  note       String?
  markedById String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  session     AttendanceSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     User                          @relation("AttendanceStudent", fields: [studentId], references: [id], onDelete: Cascade)
  markedBy    User?                         @relation("AttendanceMarker", fields: [markedById], references: [id], onDelete: SetNull)
  corrections AttendanceCorrectionRequest[]

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendance_records")
}

model AttendanceCorrectionRequest {
  id              String           @id @default(cuid())
  recordId        String
  requestedById   String
  requestedStatus AttendanceStatus
  reason          String
  status          CorrectionStatus @default(PENDING)
  reviewedById    String?
  reviewNote      String?
  reviewedAt      DateTime?
  createdAt       DateTime         @default(now())

  record      AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  requestedBy User             @relation("CorrectionRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User?            @relation("CorrectionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([recordId])
  @@index([status])
  @@map("attendance_correction_requests")
}

// ===========================================================================
// ASSIGNMENTS (Phase 1) — authoring, submission, AI-assisted evaluation (§15)
// ===========================================================================

enum AssignmentDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  EVALUATING
  EVALUATED
  RETURNED
}

// Lifecycle of an evaluation. AI never overwrites a trainer decision (§15):
// once RELEASED with a trainer score, re-evaluation is skipped.
enum EvaluationStatus {
  PENDING
  AI_COMPLETED
  NEEDS_REVIEW
  RELEASED
}

model Assignment {
  id                  String               @id @default(cuid())
  batchId             String
  courseId            String?
  moduleId            String?
  title               String
  description         String?
  instructions        String?
  difficulty          AssignmentDifficulty @default(MEDIUM)
  maxScore            Int                  @default(100)
  dueAt               DateTime?
  allowLate           Boolean              @default(false)
  maxAttempts         Int                  @default(1)
  aiEvaluationEnabled Boolean              @default(true)
  status              AssignmentStatus     @default(DRAFT)
  createdById         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  batch       Batch                  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation("AssignmentCreator", fields: [createdById], references: [id])
  criteria    RubricCriterion[]
  submissions AssignmentSubmission[]

  @@index([batchId, status])
  @@map("assignments")
}

model RubricCriterion {
  id           String  @id @default(cuid())
  assignmentId String
  title        String
  description  String?
  weight       Int     @default(10)
  order        Int     @default(0)

  assignment Assignment                 @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  scores     EvaluationCriterionScore[]

  @@index([assignmentId])
  @@map("rubric_criteria")
}

model AssignmentSubmission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  attemptNumber Int              @default(1)
  contentText   String?
  repoUrl       String?
  status        SubmissionStatus @default(DRAFT)
  submittedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  assignment  Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student     User                   @relation("SubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  evaluation  AssignmentEvaluation?
  attachments SubmissionAttachment[]

  @@unique([assignmentId, studentId, attemptNumber])
  @@index([studentId])
  @@map("assignment_submissions")
}

model SubmissionAttachment {
  id           String   @id @default(cuid())
  submissionId String
  fileName     String
  url          String
  contentType  String?
  size         Int?
  createdAt    DateTime @default(now())

  submission AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_attachments")
}

model AssignmentEvaluation {
  id            String           @id @default(cuid())
  submissionId  String           @unique
  aiScore       Int?
  trainerScore  Int?
  finalScore    Int?
  confidence    Float?
  reason        String?
  version       Int              @default(1)
  evaluatedByAi Boolean          @default(false)
  status        EvaluationStatus @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  submission      AssignmentSubmission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewedBy      User?                      @relation("EvaluationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  criterionScores EvaluationCriterionScore[]

  @@map("assignment_evaluations")
}

model EvaluationCriterionScore {
  id           String  @id @default(cuid())
  evaluationId String
  criterionId  String
  score        Int
  comment      String?

  evaluation AssignmentEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterion  RubricCriterion      @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, criterionId])
  @@map("evaluation_criterion_scores")
}

// ===========================================================================
// AI OPERATIONS (§36) — observability for every AI/heuristic job
// ===========================================================================

enum AIJobType {
  ASSIGNMENT_EVALUATION
  QUESTION_GENERATION
  PROGRESS_REPORT
  RECOVERY_PLAN
}

enum AIJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model AIJob {
  id            String      @id @default(cuid())
  type          AIJobType
  status        AIJobStatus @default(QUEUED)
  provider      String?
  model         String?
  promptVersion String?
  inputRef      String? // e.g. submissionId
  output        Json?
  error         String?
  tokensInput   Int?
  tokensOutput  Int?
  latencyMs     Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([type, status])
  @@index([inputRef])
  @@map("ai_jobs")
}

// ===========================================================================
// ASSESSMENTS (Phase 1) — tests/quizzes, auto-grading, topic performance (§16)
// ===========================================================================

enum QuestionType {
  MCQ
  MULTI_SELECT
  TRUE_FALSE
  SHORT_ANSWER
  CODING
  SQL
  CASE_STUDY
  FILE_TASK
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

model Assessment {
  id               String           @id @default(cuid())
  batchId          String
  courseId         String?
  title            String
  description      String?
  timeLimitMin     Int?
  maxAttempts      Int              @default(1)
  shuffleQuestions Boolean          @default(false)
  passingScore     Int?
  dueAt            DateTime?
  status           AssessmentStatus @default(DRAFT)
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  batch     Batch               @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy User                @relation("AssessmentCreator", fields: [createdById], references: [id])
  questions Question[]
  attempts  AssessmentAttempt[]

  @@index([batchId, status])
  @@map("assessments")
}

model Question {
  id           String               @id @default(cuid())
  assessmentId String
  type         QuestionType
  prompt       String
  topic        String? // topic tag -> topic-level performance (§16)
  skillTag     String? // links to the skill matrix (Phase 2)
  difficulty   AssignmentDifficulty @default(MEDIUM)
  points       Int                  @default(1)
  order        Int                  @default(0)
  correctText  String? // for auto-graded SHORT_ANSWER (exact/normalized match)
  explanation  String?

  assessment Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  options    QuestionOption[]
  answers    AttemptAnswer[]

  @@index([assessmentId])
  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

model AssessmentAttempt {
  id            String        @id @default(cuid())
  assessmentId  String
  studentId     String
  attemptNumber Int           @default(1)
  status        AttemptStatus @default(IN_PROGRESS)
  score         Int?
  maxScore      Int?
  percent       Int?
  startedAt     DateTime      @default(now())
  submittedAt   DateTime?
  gradedAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assessment       Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student          User               @relation("AttemptStudent", fields: [studentId], references: [id], onDelete: Cascade)
  answers          AttemptAnswer[]
  topicPerformance TopicPerformance[]

  @@unique([assessmentId, studentId, attemptNumber])
  @@index([studentId])
  @@map("assessment_attempts")
}

model AttemptAnswer {
  id                String   @id @default(cuid())
  attemptId         String
  questionId        String
  selectedOptionIds String[] // for MCQ / MULTI_SELECT / TRUE_FALSE
  textAnswer        String?
  isCorrect         Boolean?
  pointsAwarded     Int?
  needsReview       Boolean  @default(false)

  attempt  AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("attempt_answers")
}

// Per-attempt breakdown by topic — the topic-level evidence that drives the
// skill matrix and intervention engine in Phase 2 (§16, §17, §20).
model TopicPerformance {
  id        String @id @default(cuid())
  attemptId String
  topic     String
  correct   Int
  total     Int
  percent   Int

  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, topic])
  @@map("topic_performance")
}

// ===========================================================================
// NOTIFICATIONS (Phase 1) — event-driven, in-app + email, push-ready (§32)
// ===========================================================================

enum NotificationType {
  CLASS_REMINDER
  ASSIGNMENT_PUBLISHED
  ASSIGNMENT_DEADLINE
  ASSIGNMENT_EVALUATED
  ASSESSMENT_PUBLISHED
  ENROLLMENT
  ATTENDANCE_CORRECTION
  MENTOR_BOOKING
  PLACEMENT_OPPORTUNITY
  APPLICATION_UPDATE
  RISK_INTERVENTION
  RECOVERY_TASK
  PROGRESS_REPORT
  ACHIEVEMENT
  GENERAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  deepLink  String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  inAppEnabled Boolean  @default(true)
  emailEnabled Boolean  @default(true)
  mutedTypes   String[] // NotificationType values the user has muted
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationDelivery {
  id             String              @id @default(cuid())
  notificationId String
  channel        NotificationChannel
  status         DeliveryStatus      @default(PENDING)
  attempts       Int                 @default(0)
  error          String?
  sentAt         DateTime?
  createdAt      DateTime            @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status])
  @@map("notification_deliveries")
}

// ===========================================================================
// CALENDAR (Phase 1) — personal events; derived events aggregated live (§33)
// ===========================================================================

enum CalendarEventType {
  LIVE_CLASS
  ASSIGNMENT_DUE
  ASSESSMENT_DUE
  MENTOR_SESSION
  INTERVIEW
  WORKSHOP
  PERSONAL_TASK
}

// Stored calendar events (personal tasks, workshops). Live-class/deadline
// events are derived on the fly from batch schedules and assignment/assessment
// due dates so there's no duplicated source of truth.
model CalendarEvent {
  id          String            @id @default(cuid())
  userId      String?
  batchId     String?
  title       String
  description String?
  type        CalendarEventType @default(PERSONAL_TASK)
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean           @default(false)
  location    String?
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user  User?  @relation("CalendarOwner", fields: [userId], references: [id], onDelete: Cascade)
  batch Batch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
  @@index([batchId, startsAt])
  @@map("calendar_events")
}

// ===========================================================================
// SKILLS (Phase 2) — hierarchical skill matrix + per-student profile (§20)
// ===========================================================================

model SkillCategory {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  order Int    @default(0)

  skills Skill[]

  @@map("skill_categories")
}

model Skill {
  id          String  @id @default(cuid())
  categoryId  String
  parentId    String? // optional hierarchy (e.g. Pandas -> DataFrame)
  name        String
  slug        String  @unique
  description String?

  category      SkillCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  parent        Skill?         @relation("SkillHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Skill[]        @relation("SkillHierarchy")
  courseSkills  CourseSkill[]
  studentSkills StudentSkill[]

  @@index([categoryId])
  @@map("skills")
}

// Which skills a course teaches (§20).
model CourseSkill {
  courseId String
  skillId  String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([courseId, skillId])
  @@index([skillId])
  @@map("course_skills")
}

enum SkillTrend {
  NEW
  UP
  FLAT
  DOWN
}

// A student's mastery of one skill — computed by app logic from evidence (§17).
model StudentSkill {
  id              String     @id @default(cuid())
  userId          String
  skillId         String
  score           Int        @default(0) // 0..100
  confidence      Float      @default(0) // 0..1, grows with evidence
  evidenceCount   Int        @default(0)
  trend           SkillTrend @default(NEW)
  calcVersion     Int        @default(1)
  lastEvaluatedAt DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill    Skill                  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  evidence StudentSkillEvidence[]

  @@unique([userId, skillId])
  @@index([userId])
  @@map("student_skills")
}

// The raw evidence behind a StudentSkill score — explainable (§9, §17).
model StudentSkillEvidence {
  id             String   @id @default(cuid())
  studentSkillId String
  sourceType     String // e.g. "ASSESSMENT"
  sourceId       String
  topic          String?
  correct        Int
  total          Int
  createdAt      DateTime @default(now())

  studentSkill StudentSkill @relation(fields: [studentSkillId], references: [id], onDelete: Cascade)

  @@index([studentSkillId])
  @@map("student_skill_evidence")
}

// ===========================================================================
// PERFORMANCE SCORING (Phase 2) — deterministic, explainable scores (§17)
// ===========================================================================

// Current composite scores for a student. `components` stores the inputs and
// sub-scores so every number is explainable; calcVersion tracks the model.
model StudentScore {
  id                String   @id @default(cuid())
  userId            String   @unique
  performanceScore  Int      @default(0)
  engagementScore   Int      @default(0)
  consistencyScore  Int      @default(0)
  skillMasteryScore Int      @default(0)
  overallScore      Int      @default(0)
  components        Json?
  calcVersion       Int      @default(1)
  computedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([overallScore])
  @@map("student_scores")
}

// ===========================================================================
// AT-RISK DETECTION (Phase 2) — explainable risk snapshots (§18)
// ===========================================================================

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// A point-in-time risk assessment. Snapshots are only written when the picture
// meaningfully changes (level change or a material score move), so history
// stays signal, not noise. `factors` holds the contributing rules + evidence so
// nothing is an unexplained label (§9, §18).
model StudentRiskSnapshot {
  id                 String    @id @default(cuid())
  userId             String
  batchId            String?
  level              RiskLevel
  score              Int // 0..100, higher = more at risk
  factors            Json // [{ code, label, detail, value, severity, weight, contribution }]
  recommendedActions String[]
  ruleVersion        Int       @default(1)
  detectedAt         DateTime  @default(now())
  createdAt          DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch Batch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([userId, detectedAt])
  @@index([batchId, level])
  @@index([level, detectedAt])
  @@map("student_risk_snapshots")
}

// ===========================================================================
// INTERVENTIONS (Phase 2) — automated support workflow + recovery plans (§19)
// ===========================================================================

enum InterventionStatus {
  OPEN
  PLAN_READY
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

// Created automatically when risk meaningfully escalates to HIGH/CRITICAL.
// Idempotent: a student has at most one active intervention at a time (§37).
model StudentIntervention {
  id             String             @id @default(cuid())
  userId         String
  batchId        String?
  riskSnapshotId String?
  status         InterventionStatus @default(OPEN)
  reason         String // top contributing risk factors, human-readable
  riskLevel      RiskLevel
  riskScore      Int
  followUpAt     DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan RecoveryPlan?

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("student_interventions")
}

// AI-generated, schema-validated recovery plan (§19, §36). The provider and
// model are stored so every plan is traceable to how it was produced.
model RecoveryPlan {
  id             String   @id @default(cuid())
  interventionId String   @unique
  summary        String
  weakSkills     String[]
  mentorActions  String[]
  trainerActions String[]
  provider       String
  model          String?
  createdAt      DateTime @default(now())

  intervention StudentIntervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  tasks        RecoveryPlanTask[]

  @@map("recovery_plans")
}

model RecoveryPlanTask {
  id          String    @id @default(cuid())
  planId      String
  title       String
  detail      String?
  order       Int       @default(0)
  completedAt DateTime?

  plan RecoveryPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("recovery_plan_tasks")
}

// ===========================================================================
// WEEKLY PROGRESS REPORTS (Phase 2) — deterministic metrics + AI narrative (§21)
// ===========================================================================

model WeeklyProgressReport {
  id            String   @id @default(cuid())
  userId        String
  periodStart   DateTime // start of the reporting week (00:00)
  periodEnd     DateTime
  summary       String
  achievements  String[]
  improvements  String[]
  weakAreas     String[]
  nextWeekGoals String[]
  trainerNote   String?
  mentorNote    String?
  metrics       Json // the deterministic numbers the narrative is built from
  provider      String
  model         String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([userId, periodStart])
  @@map("weekly_progress_reports")
}

// ===========================================================================
// CAREER ECOSYSTEM (Phase 3) — student career profile, portfolio, resume (§25)
// ===========================================================================

enum ProfileVisibility {
  PRIVATE // only the student + admins
  PLACEMENT // + placement officers/recruiters in the org (default)
  PUBLIC // shareable link
}

// A student's career profile — the foundation applications and the placement
// pipeline reference (§25). One per user. Aggregated with the Phase 2 skill
// matrix + placement readiness to assemble a resume.
model CareerProfile {
  id          String            @id @default(cuid())
  userId      String            @unique
  headline    String? // e.g. "Aspiring Data Analyst"
  summary     String? // short professional objective / bio
  location    String?
  phone       String?
  websiteUrl  String?
  linkedinUrl String?
  githubUrl   String?
  resumeUrl   String? // link to an uploaded resume file
  openToWork  Boolean           @default(true)
  visibility  ProfileVisibility @default(PLACEMENT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    CareerProject[]
  experiences CareerExperience[]

  @@map("career_profiles")
}

// A portfolio project shown on the profile / resume.
model CareerProject {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String?
  url         String?
  skills      String[] // free-text skill tags
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile CareerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("career_projects")
}

enum ExperienceKind {
  WORK
  EDUCATION
  CERTIFICATION
  VOLUNTEER
}

// A work / education / certification entry on the profile timeline.
model CareerExperience {
  id           String         @id @default(cuid())
  profileId    String
  kind         ExperienceKind @default(WORK)
  title        String // role or qualification
  organization String
  location     String?
  startDate    DateTime
  endDate      DateTime? // null = current
  current      Boolean        @default(false)
  description  String?
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  profile CareerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("career_experiences")
}

// ===========================================================================
// PLACEMENT OPPORTUNITIES (Phase 3) — job/internship postings + discovery (§26)
// ===========================================================================

enum OpportunityType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum OpportunityStatus {
  DRAFT
  OPEN
  CLOSED
}

// A placement opportunity posted by a placement officer/recruiter for an org.
// Students discover OPEN opportunities scoped to their organization, with a
// deterministic eligibility (placement readiness) + skill-match computed on read.
model Opportunity {
  id             String            @id @default(cuid())
  organizationId String
  postedById     String
  title          String
  companyName    String
  location       String?
  type           OpportunityType   @default(FULL_TIME)
  workMode       WorkMode          @default(ONSITE)
  description    String
  requirements   String[] // skill tags used for the match
  minReadiness   Int? // placement-readiness gate (0..100); null = open to all
  openings       Int? // number of positions
  salaryMin      Int?
  salaryMax      Int?
  currency       String            @default("INR")
  applyUrl       String? // external apply link (internal applications land in M3.3)
  deadline       DateTime?
  status         OpportunityStatus @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postedBy     User          @relation("OpportunityPoster", fields: [postedById], references: [id])
  applications Application[]
  referrals    Referral[]

  @@index([organizationId, status])
  @@index([status, deadline])
  @@map("opportunities")
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

// A student's application to an opportunity (§27). One per (opportunity,
// student). Advances through review stages; every staff decision notifies the
// student. `readinessSnapshot` captures the placement-readiness at apply time
// so later readiness changes don't rewrite history.
model Application {
  id                String            @id @default(cuid())
  opportunityId     String
  studentId         String
  status            ApplicationStatus @default(APPLIED)
  coverNote         String?
  readinessSnapshot Int? // placement-readiness score at apply time
  matchSnapshot     Int? // skill-match score at apply time
  reviewedById      String?
  reviewedAt        DateTime?
  decisionNote      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  student     User        @relation("Applicant", fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy  User?       @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([opportunityId, studentId])
  @@index([studentId, status])
  @@index([opportunityId, status])
  @@map("applications")
}

// ===========================================================================
// MENTORSHIP (Phase 3) — mentor profiles, availability, bookings (§28)
// ===========================================================================

// A mentor's public profile — what students browse when choosing a mentor.
model MentorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  headline            String?
  bio                 String?
  expertise           String[] // free-text topic tags
  isAcceptingBookings Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mentor_profiles")
}

enum MentorSlotStatus {
  OPEN
  BOOKED
  CANCELLED
}

// A concrete window a mentor opens for 1:1s. Booking one flips it to BOOKED;
// cancelling a booking releases it back to OPEN.
model MentorSlot {
  id        String           @id @default(cuid())
  mentorId  String
  startsAt  DateTime
  endsAt    DateTime
  status    MentorSlotStatus @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  mentor   User            @relation("SlotMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  bookings MentorBooking[]

  @@index([mentorId, startsAt])
  @@index([status, startsAt])
  @@map("mentor_slots")
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// A student's booking of a mentor slot (§28). A slot holds at most one live
// booking — enforced by the conditional OPEN→BOOKED flip — while cancelled
// bookings are retained as history, so a freed slot can be booked again.
model MentorBooking {
  id          String        @id @default(cuid())
  slotId      String
  mentorId    String
  studentId   String
  topic       String
  note        String?
  status      BookingStatus @default(CONFIRMED)
  mentorNotes String? // written after the session
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  slot    MentorSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  mentor  User       @relation("BookingMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  student User       @relation("BookingStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([slotId])
  @@index([studentId, status])
  @@index([mentorId, status])
  @@map("mentor_bookings")
}

// ===========================================================================
// ALUMNI NETWORK (Phase 3) — outcomes, directory, success stories (§29)
// ===========================================================================

// Where a graduate landed. Self-maintained; surfaced to current students as
// proof-of-outcome and as a network to reach into.
model AlumniProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  graduationYear  Int?
  currentCompany  String?
  currentRole     String?
  industry        String?
  location        String?
  story           String? // advice / what worked, shown to current students
  linkedinUrl     String?
  isPublished     Boolean  @default(true) // opt out of the directory
  openToMentoring Boolean  @default(false)
  openToReferrals Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentCompany])
  @@index([industry])
  @@map("alumni_profiles")
}

// ===========================================================================
// NETWORK EFFECTS (Phase 4) — referrals (§30)
// ===========================================================================

enum ReferralStatus {
  PENDING
  ACKNOWLEDGED
  DECLINED
}

// A member of the network (alumnus or mentor) vouching for a student on a
// specific opportunity. Surfaces to the placement officer alongside the
// student's application, and to the student as encouragement.
model Referral {
  id            String         @id @default(cuid())
  opportunityId String
  studentId     String
  referrerId    String
  note          String
  status        ReferralStatus @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  student     User        @relation("ReferralStudent", fields: [studentId], references: [id], onDelete: Cascade)
  referrer    User        @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  reviewedBy  User?       @relation("ReferralReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([opportunityId, studentId, referrerId])
  @@index([studentId, status])
  @@index([opportunityId, status])
  @@map("referrals")
}

// ===========================================================================
// COMMUNITY Q&A (Phase 4) — a knowledge base that compounds (§31)
// ===========================================================================

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

// A question asked inside an organization's community. Tagged by topic so the
// archive stays searchable as it grows.
model CommunityQuestion {
  id             String         @id @default(cuid())
  organizationId String
  authorId       String
  title          String
  body           String
  tags           String[]
  status         QuestionStatus @default(OPEN)
  viewCount      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User              @relation("QuestionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  answers      CommunityAnswer[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("community_questions")
}

model CommunityAnswer {
  id         String   @id @default(cuid())
  questionId String
  authorId   String
  body       String
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question CommunityQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author   User                  @relation("AnswerAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  votes    CommunityAnswerVote[]

  @@index([questionId])
  @@index([authorId])
  @@map("community_answers")
}

// Upvote-only: signal without the pile-on. One vote per member per answer.
model CommunityAnswerVote {
  answerId  String
  userId    String
  createdAt DateTime @default(now())

  answer CommunityAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([answerId, userId])
  @@index([userId])
  @@map("community_answer_votes")
}

// ===========================================================================
// REPUTATION (Phase 4) — earned achievements (§32)
// ===========================================================================

// A badge a member has earned. Contribution *scores* are derived live from
// activity; achievements are persisted so each one is announced exactly once.
model Achievement {
  id        String   @id @default(cuid())
  userId    String
  code      String // matches a BADGES code in @fca/analytics
  awardedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
  @@map("achievements")
}
